<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ipos.pu.ui.controller.ChangePasswordController"
            style="-fx-background-color: #f4f4f4;">
    <center>
        <VBox alignment="CENTER" spacing="15" style="-fx-padding: 40;">
            <Label text="Change Password" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Label text="You must change your password before continuing."
                   style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
            <PasswordField fx:id="currentPasswordField" promptText="Current Password" style="-fx-pref-width: 300;"/>
            <PasswordField fx:id="newPasswordField" promptText="New Password" style="-fx-pref-width: 300;"/>
            <PasswordField fx:id="confirmPasswordField" promptText="Confirm New Password" style="-fx-pref-width: 300;"/>
            <Label fx:id="errorLabel" style="-fx-text-fill: red;"/>
            <Button text="Change Password" onAction="#onChangeClicked"
                    style="-fx-pref-width: 300; -fx-pref-height: 40; -fx-font-size: 14px;"/>
        </VBox>
    </center>
</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ipos.pu.ui.controller.LoginController"
            style="-fx-background-color: #f4f4f4;">
    <center>
        <VBox alignment="CENTER" spacing="15" style="-fx-padding: 40;">
            <Label text="Login" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            <TextField fx:id="emailField" promptText="Email" style="-fx-pref-width: 300;"/>
            <PasswordField fx:id="passwordField" promptText="Password" style="-fx-pref-width: 300;"/>
            <Label fx:id="errorLabel" style="-fx-text-fill: red;"/>
            <Button text="Login" onAction="#onLoginClicked"
                    style="-fx-pref-width: 300; -fx-pref-height: 40; -fx-font-size: 14px;"/>
            <Button text="Back" onAction="#onBackClicked"
                    style="-fx-pref-width: 300; -fx-font-size: 12px;"/>
        </VBox>
    </center>
</BorderPane>
